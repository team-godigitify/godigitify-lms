# ─────────────────────────────────────────
# Godigitify LMS — API environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────

# ── Core runtime ──
NODE_ENV=development
PORT=5000

# ── Database (Supabase Postgres) ──
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/godigitify

# ── Redis (BullMQ job queues) ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── CORS / URLs ──
CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:5000/api/v1
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────
# Email — set ONE (priority: Resend → Brevo → SMTP)
# ─────────────────────────────────────────

# Option A — Brevo HTTP API (recommended for Railway/Render, free 300/day)
#   brevo.com → API Keys → Create key
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — Resend (free 3000/month, requires verified domain)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option C — SMTP (local dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Sender shown in inbox (must be verified in Brevo or Resend)
SMTP_FROM="Godigitify CRM <noreply@godigitify.com>"

# Optional: hosted logo URL for email headers
LOGO_URL=

# ─────────────────────────────────────────
# Cloudflare R2 — file storage
# ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=godigitify-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─────────────────────────────────────────
# Meta (Lead Forms + WhatsApp Cloud API)
# All optional — system degrades gracefully when not set.
# ─────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=godigitify-webhook-2025
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_AUTO_REPLY=false
# Comma-separated form IDs to accept (empty = accept all)
META_ALLOWED_FORM_IDS=

# ─────────────────────────────────────────
# Intel Brief — AI + Data Collection (Phase 5)
# ─────────────────────────────────────────

# Anthropic Claude API — required for Intel Brief generation
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google APIs — for PageSpeed + Places/Reviews signals
# console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API, PageSpeed Insights API
GOOGLE_PLACES_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_PAGESPEED_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram scraper (third-party service — confirm vendor before Phase 5)
INSTAGRAM_SCRAPER_URL=
INSTAGRAM_SCRAPER_KEY=
